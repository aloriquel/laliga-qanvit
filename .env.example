# ─────────────────────────────────────────────
# La Liga Qanvit — Variables de entorno
# cp .env.example .env.local y rellena los valores
# ─────────────────────────────────────────────

# Supabase (obtén en app.supabase.com → tu proyecto → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...   # solo server

# Anthropic (obtén en console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=sk-ant-...

# Embeddings — elige uno de los dos providers:
OPENAI_API_KEY=sk-...                # si usas OpenAI text-embedding-3-small
VOYAGE_API_KEY=pa-...               # si usas Voyage voyage-3

# Email transaccional (Resend — resend.com)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=liga@qanvit.com

# Pipeline — Edge Function invocada por el trigger pg_net
EVALUATOR_FN_URL=http://localhost:54321/functions/v1/evaluator-pipeline
EVALUATOR_FN_SECRET=change_me_32_chars_random_secret__

# Rate limiting (Upstash Redis — upstash.com → crear Redis gratuito)
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxx...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_QANVIT_URL=https://app.qanvit.com

# Deck preview thumbnails
# VERCEL_API_URL: URL base de Vercel (prod: https://laliga.qanvit.com, preview: URL de la preview)
# Usada por la Supabase Edge Function para notificar la ruta Node de generación.
VERCEL_API_URL=http://localhost:3000
# INTERNAL_WEBHOOK_SECRET: genera con: openssl rand -hex 32
# Debe estar en Vercel (Production+Preview+Development) Y en Supabase secrets:
#   supabase secrets set INTERNAL_WEBHOOK_SECRET=<valor>
#   supabase secrets set VERCEL_API_URL=<valor>
INTERNAL_WEBHOOK_SECRET=change_me_64_hex_chars_openssl_rand_hex_32
